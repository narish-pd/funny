{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "funny",
  "compatibility_date": "2026-06-12",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  
}
